# ローカル開発: /api（Vite proxy が backend へ転送）
# 本番（Railway 等）: バックエンドの絶対 URL をビルド前に設定する
# 例: VITE_API_BASE_URL=https://your-backend.up.railway.app/api
VITE_API_BASE_URL=/api
# 開発デバッグ表示: true で検索中の実行APIを表示
VITE_FOOD_SEARCH_DEBUG_MODE=false

# 任意のビルド番号（未設定可）。設定すると「バージョン x.y.z（ビルド番号）」と表示
# VITE_APP_BUILD_NUMBER=100

# 法務・ポリシー（正式な URL を設定する。未設定時はアプリ内に TODO 画面を表示）
# TERMS_OF_SERVICE_URL 相当
# VITE_TERMS_OF_SERVICE_URL=https://example.com/terms
# PRIVACY_POLICY_URL 相当
# VITE_PRIVACY_POLICY_URL=https://example.com/privacy
# COMMERCIAL_TRANSACTIONS_URL 相当
# VITE_COMMERCIAL_TRANSACTIONS_URL=https://example.com/legal/tokushoho
# AI利用上の注意（任意）
# VITE_AI_DISCLAIMER_URL=https://example.com/ai-disclaimer
