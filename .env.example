# Anthropic API キー（カロリー推定に使用）
ANTHROPIC_API_KEY=

# Brave Search API キー（AI Web検索で優先利用。未設定時は Claude Web 検索のみ）
# https://api-dashboard.search.brave.com/ で発行
BRAVE_SEARCH_API_KEY=

# AI Web検索プロバイダ: auto | brave_only | claude_only
# auto: Brave → 0件時 Claude Web Search（推奨）
# brave_only: Brave のみ（0件は estimated_fallback）
# claude_only: Haiku計画なしで Claude Web Search 直
AI_WEB_SEARCH_PROVIDER=auto

# MySQL 設定
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=diet_ai
DB_USERNAME=diet_ai
DB_PASSWORD=diet_ai
MYSQL_ROOT_PASSWORD=root

# メール送信設定
# log: backend/data/mail.log に書き出す（ローカル開発ではこちらを推奨）
# resend: Resend API 経由で送信（本番用）
#   ※ Resend 無料プランは onboarding@resend.dev から、Resend 登録メール宛のみ送信可能
MAIL_DRIVER=log
MAIL_FROM=ダイエットアプリ <onboarding@resend.dev>
FRONTEND_URL=http://localhost:5173

# Resend 設定（MAIL_DRIVER=resend のとき）
# https://resend.com/api-keys で API キーを発行
# onboarding@resend.dev は Resend 登録メール宛のみ送信可（テスト用）
# 任意のアドレスへ送るには resend.com/domains でドメイン検証が必要
RESEND_API_KEY=
