# Anthropic API キー（カロリー推定に使用）
ANTHROPIC_API_KEY=

# Brave Search API キー（AI Web検索で優先利用。未設定時は Claude Web 検索のみ）
# https://api-dashboard.search.brave.com/ で発行
BRAVE_SEARCH_API_KEY=

# AI Web検索プロバイダ: auto | brave_only | claude_only
# auto: Brave → 0件時 Claude Web Search（推奨）
# brave_only: Brave のみ（0件は estimated_fallback）
# claude_only: Haiku計画なしで Claude Web Search 直
AI_WEB_SEARCH_PROVIDER=auto

# Claude Web Search フォールバック: off | conditional | manual | always
# 本番推奨: conditional（厳しい条件を満たす場合のみ自動実行）
# 移行: 従来互換が必要なら一時的に always → 様子を見て conditional
AI_WEB_SEARCH_CLAUDE_FALLBACK_MODE=conditional

# HTTP / deadline
AI_WEB_SEARCH_TOTAL_DEADLINE_MS=12000
AI_WEB_SEARCH_CONNECT_TIMEOUT_MS=2000
AI_WEB_SEARCH_REQUEST_TIMEOUT_MS=4000
AI_WEB_SEARCH_MAX_RESPONSE_BYTES=1500000
AI_WEB_SEARCH_MAX_REDIRECTS=3
AI_WEB_SEARCH_MAX_PARALLEL_FETCHES=3
AI_WEB_SEARCH_MAX_PARALLEL_PER_HOST=2

# キャッシュ TTL（秒）
# AI_WEB_SEARCH_CACHE_ENABLED=true
# confirmed result は WebSearchResultCache（既定 24h）
AI_WEB_SEARCH_HTML_CACHE_TTL_SECONDS=21600
AI_WEB_SEARCH_CLAUDE_NOT_FOUND_TTL_SECONDS=3600

# Claude 日次予算・サーキットブレーカー
CLAUDE_WEB_SEARCH_DAILY_BUDGET_USD=5
CLAUDE_WEB_SEARCH_MAX_REQUESTS_PER_DAY=50
CLAUDE_WEB_SEARCH_CIRCUIT_BREAKER_FAILURE_RATE=0.8
CLAUDE_WEB_SEARCH_CIRCUIT_BREAKER_MIN_SAMPLES=5
# CLAUDE_WEB_SEARCH_CIRCUIT_STOPS_MANUAL=0

# Anthropic 概算料金（USD / MTok または / request）
# ANTHROPIC_PRICE_INPUT_PER_MTOK=3
# ANTHROPIC_PRICE_OUTPUT_PER_MTOK=15
# ANTHROPIC_PRICE_CACHE_READ_PER_MTOK=0.30
# ANTHROPIC_PRICE_CACHE_WRITE_PER_MTOK=3.75
# ANTHROPIC_PRICE_WEB_SEARCH_PER_REQUEST=0.01

# MySQL 設定
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=diet_ai
DB_USERNAME=diet_ai
DB_PASSWORD=diet_ai
MYSQL_ROOT_PASSWORD=root

# メール送信設定
# log: backend/data/mail.log に書き出す（ローカル開発ではこちらを推奨）
# resend: Resend API 経由で送信（本番用）
#   ※ Resend 無料プランは onboarding@resend.dev から、Resend 登録メール宛のみ送信可能
MAIL_DRIVER=log
MAIL_FROM=ダイエットアプリ <onboarding@resend.dev>
FRONTEND_URL=http://localhost:5173

# Resend 設定（MAIL_DRIVER=resend のとき）
# https://resend.com/api-keys で API キーを発行
# onboarding@resend.dev は Resend 登録メール宛のみ送信可（テスト用）
# 任意のアドレスへ送るには resend.com/domains でドメイン検証が必要
RESEND_API_KEY=

# お問い合わせの受信先メール（運営用）。本番では必須。
# CONTACT_INQUIRY_TO=support@example.com
